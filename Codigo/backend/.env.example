PROJECT_NAME="Cognita API"

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="your-secret-key-here"

ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Neo4j connection — format: bolt://<user>:<password>@<host>:<port>
NEO4J_URL="bolt://neo4j:password@localhost:7687"

# Comma-separated list of allowed CORS origins (JSON array format)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# MinIO / Object Storage
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET_NAME="cognita-documents"
MINIO_USE_SSL=false

# Change to "s3" or another backend class name to swap storage implementations
STORAGE_BACKEND="minio"
